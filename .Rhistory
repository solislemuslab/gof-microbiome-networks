ecount(net)
# Keep only microbial taxa nodes
# Taxa nodes begin with "s__"
taxa_nodes <- grep("^s__", V(net)$name, value = TRUE)
# Create microbiome-only network
net_taxa <- induced_subgraph(net, vids = taxa_nodes)
# Count nodes and edges in the microbiome network
vcount(net_taxa)
ecount(network18_taxa)
