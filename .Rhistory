library(igraph)
edges <- read.delim(
"data/05-hernandez/associations.tsv"
)
g <- graph_from_data_frame(
d = edges[, c("X_features", "Y_features")],
directed = FALSE
)
vcount(g)
ecount(g)
plot(g)
