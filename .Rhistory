group.by = "Modularity",
fill.by = "Modularity",
pointsize = c(1, 5),
center = F,
jitter = F,
mapping_line = F,
shrink = 0.9,
linealpha = 0.2,
linecolor = "#d9d9d9"
)
library(ggplot2)
#> Warning: package 'ggplot2' was built under R version 4.5.2
library(ggnewscale)
library(ggNetView)
data("otu_tab")
otu_tab[1:5, 1:5]
data("otu_rare")
otu_tab[1:5, 1:5]
data("otu_rare_relative")
otu_rare_relative[1:5, 1:5]
data("tax_tab")
tax_tab[1:5, 1:5]
obj <- build_graph_from_mat(
mat = otu_rare_relative,
transfrom.method = "none",
method = "WGCNA",
cor.method = "pearson",
proc = "BH",
r.threshold = 0.7,
p.threshold = 0.05,
node_annotation = tax_tab
)
p1 <- ggNetView(
graph_obj = obj,
layout = "gephi",
layout.module = "adjacent",
group.by = "Modularity",
fill.by = "Modularity",
pointsize = c(1, 5),
center = F,
jitter = F,
mapping_line = F,
shrink = 0.9,
linealpha = 0.2,
linecolor = "#d9d9d9"
)
p1
# Load package
library(igraph)
# Read the network matrix
mat <- as.matrix(read.csv("network_matrix.csv", row.names = 1))
# Look at the matrix to check it loaded correctly
mat
# Make a copy of the matrix
mat_binary <- mat
# Convert all non-zero values to 1
# Keep only where an edge exists
mat_binary[mat_binary != 0] <- 1
# Create the network
g <- graph_from_adjacency_matrix(mat_binary, mode = "directed")
# Count nodes
vcount(g)
# Count edges
ecount(g)
# Load package
library(igraph)
# Read the network matrix
mat <- as.matrix(read.csv("network_matrix.csv", row.names = 1))
# Look at the matrix to check it loaded correctly
mat
# Make a copy of the matrix
mat_binary <- mat
# Convert all non-zero values to 1
# Keep only where an edge exists
mat_binary[mat_binary != 0] <- 1
# Create the network
g <- graph_from_adjacency_matrix(mat_binary, mode = "directed")
# Count nodes
vcount(g)
# Count edges
ecount(g)
plot(g)
# Compute degree
deg <- degree(g)
deg
summary(deg)
# Plot degree distribution
hist(deg, main = "Degree distribution", xlab = "Degree")
# Generate an Erdos-Renyi network with the same number of nodes and edges
# Erdos-Renyi model network
g_er <- sample_gnm(vcount(g), ecount(g), directed = TRUE)
# Compute degree for the model network
deg_er <- degree(g_er)
# Compare distributions
hist(deg, col = "cyan",
main = "Degree Comparison",
xlab = "Degree",
ylab = "Number of nodes")
hist(deg_er, col = "purple", add = TRUE)
# Generate an Erdos-Renyi network with the same number of nodes and edges
# Erdos-Renyi model network
